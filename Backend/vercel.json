{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node",
      "config": {
        "includesFiles": [
            "dist/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/images/(.*)",
      "dest": "/uploads/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.js"
    }
  ]
}